@startuml
title 系统安全机制概览

start

:用户注册;
:校验用户名/密码规则;
if (邮箱验证码有效?) then (是)
  :加密手机号 (AES);
  :哈希密码 (bcrypt);
  :创建用户并签发 JWT;
else (否)
  :返回 400;
  stop
endif

:用户登录;
if (用户存在且密码匹配?) then (是)
  :签发 JWT (user_id,is_admin,exp);
else (否)
  :返回 400/404;
  stop
endif

:访问受保护接口;
:读取 Authorization Bearer token;
if (Redis 黑名单命中?) then (是)
  :返回 401;
  stop
else (否)
  :解码 JWT 并校验 exp;
  if (用户存在?) then (是)
    :将 (User,payload) 注入依赖;
  else (否)
    :返回 401;
    stop
  endif
endif

:管理员接口访问;
if (is_admin_user?) then (是)
  :允许访问 /admin 与调试接口;
else (否)
  :返回 403;
  stop
endif

:用户登出;
:根据 token exp 计算 TTL;
:Redis setex blacklist:{token} = true;

:邮箱密码重置流程;
:Redis 保存验证码;
if (验证码校验通过?) then (是)
  :签发 reset_token(JWT+jti);
  :verify_and_consume_reset_token;
  :更新密码 (bcrypt);
else (否)
  :返回 400;
endif

:滥用/频控防护;
if (翻译接口 1 秒内<=2次?) then (是)
  :允许请求;
else (否)
  :返回 429;
endif

:AI 助手使用量<=100/月或管理员;

stop
@enduml
